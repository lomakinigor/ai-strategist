# База данных (Postgres 16+)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_strategist

# Research provider — Perplexity Sonar (real-time web + citations)
PERPLEXITY_API_KEY=
RESEARCH_MODE=mock  # mock | real

# Strategy / analytics provider — OpenRouter (DeepSeek V4 Pro by default)
OPENROUTER_API_KEY=
OPENROUTER_STRATEGY_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_PARSE_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_REFERER=https://ai-strategist-bice.vercel.app

# Vercel Postgres (заполняется автоматически при деплое на Vercel)
# POSTGRES_URL=
